# ─────────────────────────────────────────────────────────────
# .env.local  –  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────────────────

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/buildify?retryWrites=true&w=majority

# NextAuth (for admin login protection)
NEXTAUTH_SECRET=generate-a-long-random-string-here
NEXTAUTH_URL=http://localhost:3000

# Cloudinary (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email (Nodemailer – optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=info@buildifyconstruction.in

# WhatsApp Business API (optional)
WHATSAPP_API_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.buildifyconstruction.in
